# ─────────────────────────────────────────────────────────────────────────────
# 命名規則：env var 一律大寫；對應到 app/config.py 的 lowercase 欄位
# （pydantic-settings 自動把 OPENAI_API_KEY → settings.openai_api_key）
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=development
APP_NAME=project-linebot-rag-skills
APP_PORT=8000

LINE_CHANNEL_SECRET=replace-me
LINE_CHANNEL_ACCESS_TOKEN=replace-me
LINE_API_BASE=https://api.line.me

# ── AI provider selection ─────────────────────────────────────────────────────
# ai_provider controls the LLM used for routing + generation.
#   options: openai | claude | gemini | github_copilot
AI_PROVIDER=gemini

# embedding_provider controls the model used for RAG embeddings.
#   options: openai | gemini
EMBEDDING_PROVIDER=gemini

# ── OpenAI ────────────────────────────────────────────────────────────────────
#OPENAI_API_KEY=replace-me
##OPENAI_BASE_URL=https://api.openai.com/v1
#ROUTER_MODEL=gpt-4.1-mini
#GENERATOR_MODEL=gpt-4.1
#EMBEDDING_MODEL=text-embedding-3-small

# ── Anthropic / Claude  (AI_PROVIDER=claude) ─────────────────────────────────
ANTHROPIC_API_KEY=replace-me
# ROUTER_MODEL=claude-opus-4-7
# GENERATOR_MODEL=claude-opus-4-7

# ── Google Gemini  (AI_PROVIDER=gemini) ──────────────────────────────────────
GEMINI_API_KEY=replace-me
#
# 穩定版（生產環境推薦）：
ROUTER_MODEL=gemini-2.5-flash
GENERATOR_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-2
#
# 試驗版 3.1（preview，API 行為可能變動）：
# ROUTER_MODEL=gemini-3.1-flash-lite-preview
# GENERATOR_MODEL=gemini-3.1-pro-preview
# EMBEDDING_MODEL=gemini-embedding-2-preview

# ── GitHub Copilot  (AI_PROVIDER=github_copilot) ─────────────────────────────
GITHUB_COPILOT_TOKEN=replace-me
GITHUB_COPILOT_BASE_URL=https://api.githubcopilot.com
# ROUTER_MODEL=gpt-4o-mini
# GENERATOR_MODEL=gpt-4o

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co

# SUPABASE_SERVICE_ROLE_KEY 必須是「能繞過 RLS 的後端 key」，二選一即可：
#   1. 新系統「API Keys」區塊的 secret key（推薦，未來預設）：
#         SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   2. 舊系統「Project API keys」區塊的 service_role key（legacy，仍支援）：
#         SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# 不要用 publishable / anon / legacy public key — 那些前端用，被 RLS 擋。
# 此 key 擁有完整 DB 存取權，僅用於後端 ingest / worker；絕不放進前端 / 公開 repo。
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

SUPABASE_DB_URL=postgresql://postgres@db.your-project.supabase.co:5432/postgres
PGPASSWORD=replace-me

# ── RAG / app tuning ──────────────────────────────────────────────────────────
KNOWLEDGE_TOP_K=8
FINAL_CONTEXT_K=4
LINE_MAX_MESSAGE_CHARS=4500
SKILLS_DIR=skills

# ── Advanced RAG（spec-26 ~ spec-31）─────────────────────────────────────────

# 查詢轉換（spec-26）：none | hyde | step_back | decompose
QUERY_TRANSFORM_STRATEGY=none
HYDE_MODEL=gpt-4o-mini
HYDE_MAX_TOKENS=150
STEP_BACK_MODEL=gpt-4o-mini
DECOMPOSE_MAX_SUBQUERIES=3

# 混合檢索（spec-27）
HYBRID_ENABLED=false
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_KEYWORD_WEIGHT=0.3

# Reranker（spec-28）：需設 COHERE_API_KEY 或安裝 sentence-transformers
RERANKER_ENABLED=false
RERANKER_PROVIDER=cohere
RERANKER_MODEL=rerank-multilingual-v3.0
RERANKER_TOP_N=5
COHERE_API_KEY=replace-me

# Embedding 模型（spec-29）：openai | huggingface
# EMBEDDING_PROVIDER 已在上方 AI provider 區段設定
# EMBEDDING_DIMENSIONS=  # 留空 = 模型預設維度（text-embedding-3-* 可降維）

# 安全性防禦（spec-30）
SECURITY_INPUT_GUARD=true
SECURITY_OUTPUT_GUARD=true
SECURITY_POISON_SCREEN=true
SECURITY_MAX_INPUT_CHARS=1000
SECURITY_BLOCKED_REPLY=抱歉，這個問題我無法回覆。

# 串流回應（spec-31）
STREAMING_ENABLED=false
STREAMING_PLACEHOLDER=⏳ 思考中，請稍候...
